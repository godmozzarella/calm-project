{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2020",
		"allowJs": true,
		"checkJs": false,
		"resolveJsonModule": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
